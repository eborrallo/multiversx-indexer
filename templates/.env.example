# MultiversX indexer configuration
# Copy to .env and fill in your values

# Kepler API key (required for Kepler sources)
# Get one at https://projectx.mx
KEPLER_API_KEY=

# Optional: PostgreSQL connection string
# When set, uses Postgres instead of local PGLite (./indexer-data)
# Start Postgres with: docker compose up -d
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/indexer
